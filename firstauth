#!/usr/bin/env php
<?php

if (php_sapi_name() !== 'cli') {
    exit(1);
}

// Resolve autoloader: works both as a dependency (vendor/reandimo/...) and standalone
$autoloadPaths = [
    dirname(__DIR__, 2) . '/autoload.php',       // installed as composer dependency
    __DIR__ . '/vendor/autoload.php',             // running from project root
];

$autoloaded = false;
foreach ($autoloadPaths as $path) {
    if (file_exists($path)) {
        require $path;
        $autoloaded = true;
        break;
    }
}

if (!$autoloaded) {
    fwrite(STDERR, "\033[38;5;203m  вң– \033[97mCould not find Composer autoloader.\033[0m\n");
    fwrite(STDERR, "\033[38;5;245m    Run: composer install\033[0m\n\n");
    exit(1);
}

// Only needed when autoloader doesn't cover src/
if (!class_exists('reandimo\\GoogleSheetsApi\\Helper')) {
    require __DIR__ . '/src/Helper.php';
}

// в”Җв”Җв”Җ Theme & helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

const RESET  = "\033[0m";
const BOLD   = "\033[1m";
const DIM    = "\033[2m";
const ITALIC = "\033[3m";
const GREEN  = "\033[38;5;78m";
const BLUE   = "\033[38;5;75m";
const PURPLE = "\033[38;5;141m";
const YELLOW = "\033[38;5;222m";
const RED    = "\033[38;5;203m";
const CYAN   = "\033[38;5;116m";
const WHITE  = "\033[97m";
const BG_RED = "\033[48;5;52m";
const GRAY   = "\033[38;5;245m";

function supportsColor(): bool
{
    if (getenv('NO_COLOR') !== false) return false;
    if (DIRECTORY_SEPARATOR === '\\') {
        return getenv('ANSICON') !== false
            || getenv('ConEmuANSI') === 'ON'
            || str_contains(getenv('TERM') ?: '', 'xterm')
            || str_contains(php_uname('v'), 'Windows 10')
            || str_contains(php_uname('v'), 'Windows 11');
    }
    return stream_isatty(STDOUT);
}

$useColor = supportsColor();

function c(string $color, string $text): string
{
    global $useColor;
    return $useColor ? "{$color}{$text}" . RESET : $text;
}

function line(string $text = ''): void
{
    echo $text . PHP_EOL;
}

function blank(): void
{
    echo PHP_EOL;
}

function banner(): void
{
    global $useColor;

    if ($useColor) {
        // Gradient ASCII art header
        $g1 = "\033[38;5;34m";  // dark green
        $g2 = "\033[38;5;35m";
        $g3 = "\033[38;5;41m";
        $g4 = "\033[38;5;42m";
        $g5 = "\033[38;5;48m";
        $g6 = "\033[38;5;49m";  // cyan-green
        $g7 = "\033[38;5;43m";
        $g8 = "\033[38;5;44m";
        $g9 = "\033[38;5;80m";
        $ga = "\033[38;5;81m";  // bright cyan

        //           S            H            E            E            T            S
        $art = [
            "  {$g1}в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—{$g3}в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—{$g5}в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—{$g6}в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—{$g7}в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—{$g9}в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—" . RESET,
            "  {$g1}в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ{$g3}в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘{$g5}в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ{$g6}в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ{$g7}в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қ{$g9}в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ" . RESET,
            "  {$g1}в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—{$g3}в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘{$g5}в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  {$g6}в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  {$g7}   в–Ҳв–Ҳв•‘   {$g9}в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—" . RESET,
            "  {$g1}в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘{$g3}в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘{$g5}в–Ҳв–Ҳв•”в•җв•җв•қ  {$g6}в–Ҳв–Ҳв•”в•җв•җв•қ  {$g7}   в–Ҳв–Ҳв•‘   {$g9}в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘" . RESET,
            "  {$g1}в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘{$g3}в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘{$g5}в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—{$g6}в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—{$g7}   в–Ҳв–Ҳв•‘   {$g9}в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘" . RESET,
            "  {$g1}в•ҡв•җв•җв•җв•җв•җв•җв•қ{$g3}в•ҡв•җв•қ  в•ҡв•җв•қ{$g5}в•ҡв•җв•җв•җв•җв•җв•җв•қ{$g6}в•ҡв•җв•җв•җв•җв•җв•җв•қ{$g7}   в•ҡв•җв•қ   {$g9}в•ҡв•җв•җв•җв•җв•җв•җв•қ" . RESET,
        ];

        blank();
        foreach ($art as $l) line($l);
        blank();
        line(c(BOLD . WHITE, '  Google Sheets Helper') . c(DIM . GRAY, ' v1.2.0') . c(DIM, '  в”Җ  ') . c(PURPLE, 'First Auth Setup'));
        line(c(GREEN, '  ' . str_repeat('в”Ғ', 55)));
    } else {
        line('');
        line('  SHEETS вҖ” Google Sheets Helper v1.2.0');
        line('  First Auth Setup');
        line('  ' . str_repeat('в”Җ', 45));
    }

    blank();
}

function step(int $num, int $total, string $label): void
{
    line(c(PURPLE, "  [$num/$total] ") . c(BOLD . WHITE, $label));
}

function info(string $text): void
{
    line(c(CYAN, '  в„№ ') . $text);
}

function success(string $text): void
{
    line(c(GREEN, '  вң” ') . c(WHITE, $text));
}

function error(string $text): void
{
    line(c(RED, '  вң– ') . c(WHITE, $text));
}

function warn(string $text): void
{
    line(c(YELLOW, '  вҡ  ') . c(WHITE, $text));
}

function prompt(string $label, string $default = ''): string
{
    $suffix = $default !== '' ? c(DIM, " ($default)") : '';
    echo c(BLUE, '  вҖә ') . $label . $suffix . c(BLUE, ' вҖә ');
    $input = trim(fgets(STDIN));
    return $input === '' ? $default : $input;
}

function separator(): void
{
    line(c(DIM, '  ' . str_repeat('в”Җ', 45)));
}

function spinner_frame(int $i): string
{
    $frames = ['в Ӣ', 'в ҷ', 'в №', 'в ё', 'в ј', 'в ҙ', 'в Ұ', 'в §', 'в Ү', 'в Ҹ'];
    return $frames[$i % count($frames)];
}

// в”Җв”Җв”Җ Main flow в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

banner();

info(c(DIM, 'This wizard generates your ') . c(YELLOW, 'token.json') . c(DIM, ' file for API authentication.'));
info(c(DIM, 'You\'ll need your ') . c(YELLOW, 'credentials.json') . c(DIM, ' from Google Cloud Console.'));
blank();
separator();
blank();

// в”Җв”Җ Step 1: Base path в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

step(1, 3, 'Base path');
line(c(DIM, '  Working directory for resolving relative paths.'));
blank();

$defaultPath = prompt('Base path', getcwd());

// Normalize trailing separator
$defaultPath = rtrim($defaultPath, '/\\') . DIRECTORY_SEPARATOR;

blank();
success("Using: " . c(CYAN, $defaultPath));
blank();
separator();
blank();

// в”Җв”Җ Step 2: Credentials file в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

step(2, 3, 'Credentials file');
line(c(DIM, '  Path to your credentials.json (relative to base path).'));
blank();

$credentialFilePath = prompt('Credentials file', 'credentials.json');

$fullCredentialPath = $defaultPath . ltrim($credentialFilePath, '/\\');

if (!is_file($fullCredentialPath)) {
    blank();
    error('File not found: ' . c(DIM, $fullCredentialPath));
    blank();
    line(c(DIM, '  Make sure you\'ve downloaded ') . c(YELLOW, 'credentials.json') . c(DIM, ' from:'));
    line(c(BLUE, '  https://console.cloud.google.com/apis/credentials'));
    blank();
    exit(1);
}

blank();
success('Found: ' . c(CYAN, $fullCredentialPath));
blank();
separator();
blank();

// в”Җв”Җ Step 3: Token destination в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

step(3, 3, 'Token destination');
line(c(DIM, '  Where to save the generated token.json file.'));
blank();

$tokenDestination = prompt('Token file', 'token.json');

$fullTokenPath = $defaultPath . ltrim($tokenDestination, '/\\');

if (file_exists($fullTokenPath)) {
    blank();
    warn('Token already exists: ' . c(DIM, $fullTokenPath));
    info('You can already access the API. Delete the file to re-authenticate.');
    blank();
    exit(0);
}

blank();
success('Will save to: ' . c(CYAN, $fullTokenPath));
blank();
separator();
blank();

// в”Җв”Җ Auth flow в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

line(c(BOLD . WHITE, '  Authenticating with Google...'));
blank();

try {
    $helper = new reandimo\GoogleSheetsApi\Helper($fullCredentialPath);
    $helper->firstAuth($fullTokenPath);
} catch (\Exception $e) {
    blank();
    error($e->getMessage());
    blank();
    exit(1);
}

blank();
separator();
blank();

// в”Җв”Җ Done в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

$doneLines = [
    c(GREEN, '  в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ'),
    c(GREEN, '  в”Ӯ') . c(BOLD . WHITE, '          Authentication complete!') . c(GREEN, '          в”Ӯ'),
    c(GREEN, '  в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ'),
];
foreach ($doneLines as $l) line($l);
blank();

success('Token saved to: ' . c(CYAN, $fullTokenPath));
blank();
info('You can now use the library:');
blank();
line(c(DIM, '    $sheet = new \\reandimo\\GoogleSheetsApi\\Helper('));
line(c(DIM, '        \'') . c(YELLOW, basename($fullCredentialPath)) . c(DIM, '\','));
line(c(DIM, '        \'') . c(YELLOW, basename($fullTokenPath)) . c(DIM, '\''));
line(c(DIM, '    );'));
blank();
line(c(DIM . ITALIC, '  Happy coding! ') . c(GREEN, 'в– '));
blank();
